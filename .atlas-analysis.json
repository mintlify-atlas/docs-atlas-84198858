    "MenuBarManager - Menu bar player",
    "MiniPlayerManager - Mini player window",
    "AISearchViewModel - AI-powered search",
    "PythonServiceManager - Python backend bridge",
    "GeminiService - Gemini AI integration",
    "UpdateManager - Auto-update service",
    "GlobalHotkeyManager - Hotkey registration",
    "Track - Music track model",
    "SearchResult - Search result model",
    "Playlist - Playlist model",
